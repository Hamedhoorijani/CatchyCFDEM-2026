FoamFile
{
    version     2.0;
    format      ascii;
    class       dictionary;
    location    "system";
    object      setFieldsDict;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

defaultFieldValues
(
    volScalarFieldValue eCond 1e-5

);

regions
(
    boxToCell
    {
        box (0.0 0.0 -0.008) (0.16 1.0 0.008);
        fieldValues
        (
            volScalarFieldValue eCond 2700
        );
    }
);


