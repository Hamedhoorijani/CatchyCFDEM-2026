FoamFile
{
    version     2.0;
    format      ascii;
    class       dictionary;
    location    "system";
    object      controlDict;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

libs            ("libcatchyFiniteVolume.so");

application     cfdemSolverRhoPimple;

startFrom       startTime;

startTime       0;

stopAt          endTime;

endTime         1;

deltaT          0.00000;

writeControl    adjustableRunTime;

writeInterval   0.01;

purgeWrite      0;

writeFormat     ascii;

writePrecision  5;

writeCompression compressed;

timeFormat      general;

timePrecision   7;

runTimeModifiable yes;

functions
{
    //#includeFunc    "outletAverage"
    //#includeFunc    "volAverage"
}
// ************************************************************************* //
